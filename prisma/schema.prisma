  tipo             TipoImpuesto
  porcentaje       Decimal      @db.Decimal(7, 4)
  incluidoEnPrecio Boolean      @default(false) @map("incluido_en_precio")
  activo           Boolean      @default(true)
  vigenteDesde     DateTime     @map("vigente_desde") @db.Date
  vigenteHasta     DateTime?    @map("vigente_hasta") @db.Date
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  deletedAt        DateTime?    @map("deleted_at")
  createdById      String?      @map("created_by") @db.Uuid
  updatedById      String?      @map("updated_by") @db.Uuid

  empresa   Empresa            @relation(fields: [empresaId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  createdBy Usuario?           @relation("ImpuestoCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy Usuario?           @relation("ImpuestoUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  productos ProductoImpuesto[]

  @@unique([empresaId, codigo])
  @@index([tipo, activo])
  @@index([deletedAt])
  @@map("impuestos")
}

/// Módulo: Auditoría
model Auditoria {
  id            String          @id @default(uuid()) @db.Uuid
  usuarioId     String?         @map("usuario_id") @db.Uuid
  tabla         String          @db.VarChar(120)
  registroId    String?         @map("registro_id") @db.Uuid
  accion        AccionAuditoria
  fechaEvento   DateTime        @default(now()) @map("fecha_evento")
  valorAnterior Json?           @map("valor_anterior")
  valorNuevo    Json?           @map("valor_nuevo")
  direccionIp   String?         @map("direccion_ip") @db.VarChar(45)
  userAgent     String?         @map("user_agent") @db.VarChar(255)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")
  createdById   String?         @map("created_by") @db.Uuid
  updatedById   String?         @map("updated_by") @db.Uuid

  usuario   Usuario? @relation("AuditoriaActor", fields: [usuarioId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdBy Usuario? @relation("AuditoriaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  updatedBy Usuario? @relation("AuditoriaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([usuarioId, fechaEvento])
  @@index([tabla, fechaEvento])
  @@index([registroId])
  @@index([deletedAt])
  @@map("auditoria")
}
